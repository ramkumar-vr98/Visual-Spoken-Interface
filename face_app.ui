  <property name="styleSheet">
   <string notr="true">/* ================= GLOBAL ================= */
QWidget {
    background-color: #0b1220;
    color: #e6edf7;
    font-family: Segoe UI, Arial;
    font-size: 10.5pt;
}

/* ================= TITLE LABEL ================= */
QLabel#titleLabel {
    color: #6ee7ff;
    font-size: 22pt;
    font-weight: bold;
}

/* ================= CAMERA VIEW ================= */
QLabel#camera_label {
    background-color: #050a12;
    border: 2px solid #2a3a52;
    border-radius: 12px;
    color: #6b7c93;
}

/* ================= RESULT BANNER ================= */
QLabel#resultBanner {
    border-radius: 12px;
    padding: 12px;
    font-size: 16pt;
    font-weight: bold;
    background-color: #111a2b;
    border: 2px solid #22324a;
}

/* ================= BUTTONS ================= */
QPushButton {
    background-color: #1e2a3a;
    border: 1px solid #2f4a6a;
    border-radius: 8px;
    padding: 8px;
    color: #cfe8ff;
    font-weight: 600;
}

/* Hover */
QPushButton:hover {
    background-color: #26384f;
    border: 1px solid #3b82f6;
}

/* Pressed */
QPushButton:pressed {
    background-color: #1b2c3f;
}

/* START BUTTON (GREEN) */
QPushButton#start_button {
    background-color: #0f9d58;
    border: 1px solid #17c96b;
    color: white;
}

QPushButton#start_button:hover {
    background-color: #12b766;
}

/* STOP BUTTON (RED) */
QPushButton#stop_button {
    background-color: #b42318;
    border: 1px solid #ef4444;
    color: white;
}

QPushButton#stop_button:hover {
    background-color: #d92d20;
}

/* ================= PANELS ================= */
QListWidget, QTextEdit {
    background-color: #111827;
    border: 1px solid #2a3a52;
    border-radius: 8px;
    color: #d1d5db;
}

/* ================= STATUS BAR ================= */
QStatusBar {
    background-color: #111827;
    color: #cbd5e1;
    border-top: 1px solid #2a3a52;
}</string>
