from pathlib import Path
import json
import cv2
import torch
from torch import nn
from torchvision import transforms, models
from PIL import Image
from deepface import DeepFace

# =========================
# CONFIG
# =========================
MODEL_PATH = Path(r"C:\Users\ram41\OneDrive\Desktop\PSB\Visual & Spoken Interfaces\CW2_vsi\VSI_Codes\identity_model.pth")
CLASS_NAMES_PATH = Path(r"C:\Users\ram41\OneDrive\Desktop\PSB\Visual & Spoken Interfaces\CW2_vsi\VSI_Codes\class_names.json")

IMG_SIZE = 224
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")
CASCADE_PATH = cv2.data.haarcascades + "haarcascade_frontalface_default.xml"

CONFIDENCE_THRESHOLD = 55.0


def load_class_names():
    with open(CLASS_NAMES_PATH, "r") as f:
        return json.load(f)


def build_identity_model(num_classes: int):
    model = models.resnet18(weights=None)
    model.fc = nn.Linear(model.fc.in_features, num_classes)
    model.load_state_dict(torch.load(MODEL_PATH, map_location=DEVICE))
    model = model.to(DEVICE)
    model.eval()
    return model


def predict_identity(model, class_names, face_bgr):
    face_rgb = cv2.cvtColor(face_bgr, cv2.COLOR_BGR2RGB)
    face_pil = Image.fromarray(face_rgb)

    transform = transforms.Compose([
        transforms.Resize((IMG_SIZE, IMG_SIZE)),
        transforms.ToTensor(),
        transforms.Normalize([0.485, 0.456, 0.406],
                             [0.229, 0.224, 0.225]),
    ])

    tensor = transform(face_pil).unsqueeze(0).to(DEVICE)

    with torch.no_grad():
        outputs = model(tensor)
        probs = torch.softmax(outputs, dim=1)
        confidence, pred_idx = torch.max(probs, dim=1)

    predicted_name = class_names[pred_idx.item()]
    confidence_percent = confidence.item() * 100

    if confidence_percent < CONFIDENCE_THRESHOLD:
        predicted_name = "Unknown"

    return predicted_name, confidence_percent


def predict_emotion(face_bgr):
    try:
        result = DeepFace.analyze(
            img_path=face_bgr,
            actions=["emotion"],
            enforce_detection=False,
            detector_backend="opencv",
            silent=True
        )

        print("DeepFace raw result:", result)

        if isinstance(result, list):
            result = result[0]

        emotion = result.get("dominant_emotion", "Unknown")
        return emotion

    except Exception as e:
        print("Emotion error occured")
        return "Unknown"


def main():
    class_names = load_class_names()
    identity_model = build_identity_model(len(class_names))

    face_cascade = cv2.CascadeClassifier(CASCADE_PATH)
    if face_cascade.empty():
        print("Failed to load Haar cascade.")
        return

    cap = cv2.VideoCapture(0)
    if not cap.isOpened():
        print("Could not open webcam.")
        return

    print("Press 'q' to quit.")

    while True:
        ret, frame = cap.read()
        if not ret:
            print("Failed to read frame from webcam.")
            break

        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

        faces = face_cascade.detectMultiScale(
            gray,
            scaleFactor=1.05,
            minNeighbors=4,
            minSize=(80, 80)
        )

        for (x, y, w, h) in faces:
            pad_x = int(0.08 * w)
            pad_y = int(0.08 * h)

            x1 = max(0, x - pad_x)
            y1 = max(0, y - pad_y)
            x2 = min(frame.shape[1], x + w + pad_x)
            y2 = min(frame.shape[0], y + h + pad_y)

            face_crop = frame[y1:y2, x1:x2]
            if face_crop.size == 0:
                continue

            predicted_name, confidence = predict_identity(identity_model, class_names, face_crop)
            
            if face_crop.shape[0] < 48 or face_crop.shape[1] < 48:
                emotion = "Unknown"
            else:
                emotion = predict_emotion(face_crop)

            label = f"{predicted_name} | {emotion} | {confidence:.1f}%"



            cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 0), 2)
            cv2.putText(
                frame,
                label,
                (x1, max(y1 - 10, 25)),
                cv2.FONT_HERSHEY_SIMPLEX,
                0.7,
                (0, 255, 0),
                2
            )

        cv2.imshow("Live Identity + Emotion Recognition", frame)

        if cv2.waitKey(1) & 0xFF == ord("q"):
            break

    cap.release()
    cv2.destroyAllWindows()


if __name__ == "__main__":
    main()
