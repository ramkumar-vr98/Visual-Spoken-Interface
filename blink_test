import cv2
import mediapipe as mp
import math


def euclidean(p1, p2):
    return math.hypot(p1.x - p2.x, p1.y - p2.y)


def eye_aspect_ratio(landmarks, top1, top2, bottom1, bottom2, left_corner, right_corner):
    vertical_1 = euclidean(landmarks[top1], landmarks[bottom1])
    vertical_2 = euclidean(landmarks[top2], landmarks[bottom2])
    horizontal = euclidean(landmarks[left_corner], landmarks[right_corner])

    if horizontal == 0:
        return 0.0

    ear = (vertical_1 + vertical_2) / (2.0 * horizontal)
    return ear


mp_face_mesh = mp.solutions.face_mesh
mp_draw = mp.solutions.drawing_utils

# FaceMesh landmarks for blink test
# Left eye
LEFT_EYE = {
    "top1": 159,
    "top2": 160,
    "bottom1": 145,
    "bottom2": 144,
    "left_corner": 33,
    "right_corner": 133
}

# Right eye
RIGHT_EYE = {
    "top1": 386,
    "top2": 385,
    "bottom1": 374,
    "bottom2": 380,
    "left_corner": 362,
    "right_corner": 263
}

EAR_THRESHOLD = 0.20
CONSEC_FRAMES = 2


def main():
    cap = cv2.VideoCapture(0)
    if not cap.isOpened():
        print("Could not open webcam.")
        return

    left_blink_count = 0
    right_blink_count = 0

    left_closed_frames = 0
    right_closed_frames = 0

    left_eye_closed = False
    right_eye_closed = False

    with mp_face_mesh.FaceMesh(
        static_image_mode=False,
        max_num_faces=1,
        refine_landmarks=True,
        min_detection_confidence=0.5,
        min_tracking_confidence=0.5
    ) as face_mesh:

        while True:
            ret, frame = cap.read()
            if not ret:
                break

            frame = cv2.flip(frame, 1)
            rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            results = face_mesh.process(rgb)

            left_status = "Open"
            right_status = "Open"

            if results.multi_face_landmarks:
                for face_landmarks in results.multi_face_landmarks:
                    mp_draw.draw_landmarks(
                        frame,
                        face_landmarks,
                        mp_face_mesh.FACEMESH_CONTOURS,
                        landmark_drawing_spec=None,
                        connection_drawing_spec=mp.solutions.drawing_styles.get_default_face_mesh_contours_style()
                    )

                    lm = face_landmarks.landmark

                    left_ear = eye_aspect_ratio(
                        lm,
                        LEFT_EYE["top1"], LEFT_EYE["top2"],
                        LEFT_EYE["bottom1"], LEFT_EYE["bottom2"],
                        LEFT_EYE["left_corner"], LEFT_EYE["right_corner"]
                    )

                    right_ear = eye_aspect_ratio(
                        lm,
                        RIGHT_EYE["top1"], RIGHT_EYE["top2"],
                        RIGHT_EYE["bottom1"], RIGHT_EYE["bottom2"],
                        RIGHT_EYE["left_corner"], RIGHT_EYE["right_corner"]
                    )

                    # Left eye blink logic
                    if left_ear < EAR_THRESHOLD:
                        left_closed_frames += 1
                        left_status = "Closed"
                        if left_closed_frames >= CONSEC_FRAMES and not left_eye_closed:
                            left_blink_count += 1
                            left_eye_closed = True
                    else:
                        left_closed_frames = 0
                        left_eye_closed = False
                        left_status = "Open"

                    # Right eye blink logic
                    if right_ear < EAR_THRESHOLD:
                        right_closed_frames += 1
                        right_status = "Closed"
                        if right_closed_frames >= CONSEC_FRAMES and not right_eye_closed:
                            right_blink_count += 1
                            right_eye_closed = True
                    else:
                        right_closed_frames = 0
                        right_eye_closed = False
                        right_status = "Open"

                    cv2.putText(
                        frame,
                        f"Left Eye: {left_status} | Blinks: {left_blink_count} | EAR: {left_ear:.2f}",
                        (20, 30),
                        cv2.FONT_HERSHEY_SIMPLEX,
                        0.6,
                        (0, 255, 0),
                        2
                    )

                    cv2.putText(
                        frame,
                        f"Right Eye: {right_status} | Blinks: {right_blink_count} | EAR: {right_ear:.2f}",
                        (20, 60),
                        cv2.FONT_HERSHEY_SIMPLEX,
                        0.6,
                        (0, 255, 0),
                        2
                    )

                    break
            else:
                cv2.putText(
                    frame,
                    "No face detected",
                    (20, 30),
                    cv2.FONT_HERSHEY_SIMPLEX,
                    0.7,
                    (0, 0, 255),
                    2
                )

            cv2.imshow("Blink Test - Press Q to Quit", frame)

            key = cv2.waitKey(1) & 0xFF
            if key == ord("q"):
                break

    cap.release()
    cv2.destroyAllWindows()


if __name__ == "__main__":
    main()
